LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Used to generate/query semantic embeddings for the knowledge base
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Optional override for config/agent.properties
AGENT_CONFIG_PATH=config/agent.properties

# Telephony settings (Vobiz SIP -> LiveKit)
# Set to `vobiz` for this integration.
TELEPHONY_PROVIDER=vobiz

# auto: Detect SIP participants and enable telephony optimizations automatically.
# on: Force telephony mode for all sessions.
# off: Disable telephony mode.
TELEPHONY_MODE=auto

# Optional metadata used in logs and setup scripts.
VOBIZ_SIP_TRUNK_NAME=vobiz-inbound
VOBIZ_PHONE_NUMBER=
VOBIZ_SIP_DOMAIN=
VOBIZ_SIP_USERNAME=
VOBIZ_SIP_PASSWORD=

# Vobiz REST API credentials (from https://console.vobiz.ai -> Settings)
# Auth ID looks like: MA_XXXXXX
# Auth Token looks like: sk_live_XXXXXXXXXXXX
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=
