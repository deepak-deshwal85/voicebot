LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Multi-tenant worker (single agent on your infra)
AGENT_NAME=voice-agent
DEFAULT_CLIENT_ID=client-1

# Used to generate/query semantic embeddings for the knowledge base
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Local testing: simulate SIP trunk phone without placing a call
# TENANT_PHONE_OVERRIDE=+911171366880

# Telephony settings (Vobiz SIP -> LiveKit Cloud)
TELEPHONY_PROVIDER=vobiz
TELEPHONY_MODE=auto

# Shared Vobiz credentials for setup scripts (per-client DIDs live in client configs)
VOBIZ_SIP_TRUNK_NAME=vobiz-inbound
VOBIZ_SIP_DOMAIN=
VOBIZ_SIP_USERNAME=
VOBIZ_SIP_PASSWORD=

# Vobiz REST API credentials (from https://console.vobiz.ai -> Settings)
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=
