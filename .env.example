LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Multi-tenant worker
AGENT_NAME=telephone-agent
DEFAULT_CLIENT_ID=client-1

OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Knowledge preload at call connect (background; does not block greeting)
# PDF default on (~300KB). Website default off (~60MB per tenant in worker memory).
PRELOAD_PDF_KNOWLEDGE=true
PRELOAD_WEBSITE_KNOWLEDGE=false

# Local testing without a phone call
# TENANT_PHONE_OVERRIDE=+911171366880

# Vobiz SIP (for scripts/setup-sip.sh)
VOBIZ_SIP_USERNAME=
VOBIZ_SIP_PASSWORD=
VOBIZ_SIP_DOMAIN=
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=
