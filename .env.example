LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Telephony settings (Vobiz SIP -> LiveKit)
# Set to `vobiz` for this integration.
TELEPHONY_PROVIDER=vobiz

# auto: Detect SIP participants and enable telephony optimizations automatically.
# on: Force telephony mode for all sessions.
# off: Disable telephony mode.
TELEPHONY_MODE=auto

# Optional metadata used in logs and setup scripts.
VOBIZ_SIP_TRUNK_NAME=vobiz-inbound
VOBIZ_PHONE_NUMBER=
VOBIZ_SIP_DOMAIN=
VOBIZ_SIP_USERNAME=
VOBIZ_SIP_PASSWORD=
